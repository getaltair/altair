# PostgreSQL
POSTGRES_USER=altair_user
POSTGRES_PASSWORD=change_me_in_production

# PowerSync
POWERSYNC_URL=http://localhost:8082
POWERSYNC_JWT_JWKS_URL=http://altair-server:3000/api/auth/.well-known/jwks.json

# Server auth (RS256 JWT)
# Generate: openssl genrsa 2048 | base64 -w0
JWT_PRIVATE_KEY=<base64-encoded PEM>

# DEV ONLY — DO NOT USE IN PRODUCTION
JWT_PRIVATE_

# Server
SERVER_URL=http://localhost:3000

# Database URL (used by sqlx and apps/server)
DATABASE_URL=postgres://altair_user:change_me_in_production@localhost:5432/altair_db

# RustFS / S3
RUSTFS_ACCESS_KEY=change_me_rustfs_access_key
RUSTFS_SECRET_KEY=change_me_rustfs_secret_key

# sqlx offline mode
SQLX_OFFLINE=true
