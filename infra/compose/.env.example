# PostgreSQL
POSTGRES_USER=altair_user
POSTGRES_PASSWORD=change_me_in_production

# Zitadel
ZITADEL_MASTERKEY=change_me_32_chars_minimum_here__

# Zitadel admin PAT (used only by zitadel-setup.sh — not needed at runtime)
ZITADEL_ADMIN_PAT=

# Zitadel OIDC (filled in after running infra/scripts/zitadel-setup.sh)
ZITADEL_CLIENT_ID=
ZITADEL_JWKS_URL=

# PowerSync
POWERSYNC_URL=http://localhost:8082
POWERSYNC_JWT_JWKS_URL=http://zitadel:8080/oauth/v2/keys

# Database URL (used by sqlx and apps/server)
DATABASE_URL=postgres://altair_user:change_me_in_production@localhost:5432/altair_db

# Garage / S3
GARAGE_ADMIN_TOKEN=change_me_garage_admin
GARAGE_RPC_SECRET=change_me_garage_rpc

# sqlx offline mode
SQLX_OFFLINE=true
