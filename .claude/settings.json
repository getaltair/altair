{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write(*.kt)",
				"hooks": [
					{
						"type": "command",
						"command": "./gradlew ktlintCheck --daemon -q",
						"timeout": 30
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash(git push*)",
				"hooks": [
					{
						"type": "command",
						"command": "git diff --staged --name-only | xargs grep -l 'TODO\\|FIXME' && echo 'Warning: Pushing code with TODOs'"
					}
				]
			}
		]
	}
}
