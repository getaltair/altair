[run]
# Specify the source code directory
source = altair

# Omit files/directories from coverage
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */alembic/versions/*
    */.venv/*
    */venv/*
    */site-packages/*
    */__init__.py

# Run tests in parallel if using pytest-xdist
parallel = True

[report]
# Show missing lines in coverage report
show_missing = True

# Exclude lines from coverage analysis
exclude_lines =
    # Standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code
    def __repr__
    def __str__

    # Don't complain if tests don't hit defensive assertion code
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Don't complain about abstract methods
    @abstractmethod
    @abc.abstractmethod

    # Don't complain about protocol methods
    @protocol
    ...

# Precision for coverage percentage
precision = 2

# Fail if coverage is below this threshold (70%)
fail_under = 70

[html]
# HTML report directory
directory = htmlcov

[xml]
# XML report for CI/CD tools (Codecov, Coveralls, etc.)
output = coverage.xml
