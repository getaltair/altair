{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AttachmentRecord",
  "type": "object",
  "required": [
    "id",
    "storageKey",
    "originalFilename",
    "mimeType",
    "sizeBytes",
    "processingStatus",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "storageKey": {
      "type": "string"
    },
    "originalFilename": {
      "type": "string"
    },
    "mimeType": {
      "type": "string"
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "processingStatus": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
