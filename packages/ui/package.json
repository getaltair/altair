{
  "name": "@altair/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared UI components for Altair apps",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package -o dist",
    "dev": "svelte-package -w -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src/",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist .svelte-kit"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.15.1",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
