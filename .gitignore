# =============================================================================
# Altair — Monorepo .gitignore
# =============================================================================

# =============================================================================
# Rust (apps/server/)
# =============================================================================
**/target/
**/*.rs.bk
*.pdb

# =============================================================================
# Node / Bun (apps/web/)
# =============================================================================
**/node_modules/
*.tsbuildinfo
.svelte-kit/
build/
dist/
.vite/
vite.config.ts.timestamp-*

# =============================================================================
# Android / Kotlin (apps/android/)
# =============================================================================
*.iml
.gradle/
local.properties
.idea/
*.apk
*.aab
*.ap_
*.dex
*.class
*.log
*.jar
!apps/android/gradle/wrapper/gradle-wrapper.jar
*.aar
captures/
.externalNativeBuild/
.cxx/
app/build/
**/build/

# =============================================================================
# Tauri (apps/desktop/ — v2)
# =============================================================================
# Covered by Rust target/ and Node node_modules/ above

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# =============================================================================
# Database
# =============================================================================
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
credentials.json
service-account.json

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# =============================================================================
# Tooling
# =============================================================================
# mise
.mise.local.toml

# Coverage & test artifacts
coverage/
*.lcov
.nyc_output/
htmlcov/
test-results/

# Cargo test target (worktree isolation)
/tmp/cargo-target/

# =============================================================================
# Claude Code / AI tooling
# =============================================================================
# .claude/ is intentionally tracked (contains rules/, agents/, commands/, skills/)
# Ignore ephemeral state
.cortex/
.claude/hooks/skill-activation/.state/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
