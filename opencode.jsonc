{
  "$schema": "https://opencode.ai/config.json",
  "categories": {
    "planning": {
      "model": "zai-coding-plan/glm-5",
      "temperature": 0.0
    },
    "quick": {
      "model": "zai-coding-plan/glm-4.7-flash",
      "temperature": 0.0
    },
    "implementation": {
      "model": "zai-coding-plan/glm-4.7",
      "temperature": 0.1
    }
  },
  "agents": {
    "plan": {
      "model": "zai-coding-plan/glm-5",
      "temperature": 0.0
    },
    "build": {
      "model": "zai-coding-plan/glm-4.7",
      "temperature": 0.1
    }
  },
  "features": {
    "parallel_qa": true,
    "context_aware_compaction": true
  }
}
