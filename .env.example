# Root Docker Compose environment for local Postgres + PowerSync.
# Copy to `.env` before running `docker compose up -d`.

# Postgres bootstrap credentials and default app database.
POSTGRES_USER=root
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=local

# PowerSync replication source database inside Docker network.
PS_DATABASE_URI=postgresql://root:mysecretpassword@postgres:5432/local

# PowerSync storage database inside Docker network.
PS_STORAGE_URI=postgresql://root:mysecretpassword@postgres:5432/powersync_storage

# PowerSync admin token for local diagnostics only.
# Replace with a strong secret outside development.
PS_ADMIN_TOKEN=dev-admin-token-change-in-production
