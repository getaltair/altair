# Altair Server Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration (REQUIRED)
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# For Docker Compose: postgresql://altair:altair_dev@postgres:5432/altair
DATABASE_URL=postgresql://altair:altair_dev@postgres:5432/altair

# Server Configuration
# Port the server will listen on (default: 3000)
PORT=3000

# Logging Configuration
# RUST_LOG sets the log level filter
# Options: error, warn, info, debug, trace
# For development: debug
# For production: warn or info
RUST_LOG=info

# Environment Configuration
# Application environment identifier
# Options: development, production
APP_ENV=development

# Usage Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Add .env to .gitignore (already done in this repo)
# 4. Run: cargo run or docker compose up
