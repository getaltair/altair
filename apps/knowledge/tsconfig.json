{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "composite": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vite/client"],
    "paths": {
      "@altair/ui": ["../../packages/ui/src"],
      "@altair/bindings": ["../../packages/bindings/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.js", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
